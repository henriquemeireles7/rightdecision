{
  "name": "decisions",
  "module": "platform/server/app.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run css:build && bun run build:client && (bun run client:dev & bun run --hot platform/server/app.ts)",
    "build": "bun run css:build && bun run build:client && bun build platform/server/app.ts --outdir dist --target bun --external isomorphic-dompurify",
    "css:build": "bunx @tailwindcss/cli -i styles/global.css -o public/styles.css --minify",
    "css:dev": "bunx @tailwindcss/cli -i styles/global.css -o public/styles.css --watch",
    "build:client": "bun platform/scripts/build-client.ts",
    "client:dev": "bun platform/scripts/build-client.ts --watch",
    "start": "bun run dist/app.js",
    "check": "bunx biome ci . && tsc --noEmit && bun run build:client && bun platform/scripts/harden-check.ts && bun test",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test --grep unit",
    "test:integration": "bun test --grep integration",
    "lint": "bunx biome check --write .",
    "format": "bunx biome format --write .",
    "db:generate": "bun drizzle-kit generate",
    "db:migrate": "bun platform/scripts/migrate.ts",
    "db:seed": "bun platform/scripts/seed-v2.ts",
    "db:studio": "bun drizzle-kit studio",
    "indexnow": "bun scripts/post-deploy-indexnow.ts",
    "freshness": "bun scripts/freshness.ts",
    "content:check": "bun scripts/content-quality.ts",
    "seo-health": "bun scripts/seo-health.ts",
    "validate-profiles": "bun content/profiles/validate.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@happy-dom/global-registrator": "^20.10.2",
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/preact": "^3.2.4",
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.10.2",
    "knip": "^6.3.1",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "knip": {
    "entry": [
      "platform/server/index.ts",
      "client/*/index.tsx"
    ],
    "project": [
      "**/*.ts",
      "**/*.tsx"
    ],
    "ignore": [
      ".claude/hooks/**",
      ".claude/hooks/lib/**",
      ".claude/skills/**/scripts/**",
      ".claude/skills/gstack/**",
      "styles/global.css",
      "platform/scripts/seed-*.ts",
      "platform/scripts/validate-block-ids.ts",
      "**/test/index.ts",
      "features/(shared)/website/blog-index.tsx",
      "features/(life)/wins/wins-board.tsx",
      "features/(life)/course/navigation.tsx",
      "features/(life)/course/time-nudge.tsx",
      "features/(shared)/drip-email/scheduler.ts",
      "features/(shared)/website/docs/docs-scripts.ts"
    ],
    "ignoreDependencies": [
      "tailwindcss"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/s3-request-presigner": "^3.1026.0",
    "@hono/zod-validator": "^0.7.6",
    "@resvg/resvg-js": "^2.6.2",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "hls.js": "^1.6.16",
    "hono": "^4.12.10",
    "isomorphic-dompurify": "^3.8.0",
    "jose": "^6.2.2",
    "marked": "^18.0.0",
    "postgres": "^3.4.8",
    "posthog-node": "^5.29.1",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.7",
    "resend": "^6.10.0",
    "satori": "^0.26.0",
    "stripe": "^22.0.0",
    "tus-js-client": "^4.3.1",
    "zod": "^4.3.6"
  }
}
