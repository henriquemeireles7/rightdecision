{
  "name": "decisions",
  "module": "platform/server/app.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run css:build && bun run --hot platform/server/app.ts",
    "build": "bun run css:build && bun build platform/server/app.ts --outdir dist --target bun",
    "css:build": "bunx @tailwindcss/cli -i styles/global.css -o public/styles.css --minify",
    "css:dev": "bunx @tailwindcss/cli -i styles/global.css -o public/styles.css --watch",
    "start": "bun run dist/app.js",
    "check": "bunx biome ci . && tsc --noEmit && bun platform/scripts/harden-check.ts && bun test",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test --grep unit",
    "test:integration": "bun test --grep integration",
    "lint": "bunx biome check --write .",
    "format": "bunx biome format --write .",
    "db:generate": "bun drizzle-kit generate",
    "db:migrate": "bun platform/scripts/migrate.ts",
    "db:seed": "bun platform/scripts/seed.ts",
    "db:studio": "bun drizzle-kit studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/cli": "^4.2.2",
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/s3-request-presigner": "^3.1026.0",
    "@hono/zod-validator": "^0.7.6",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.10",
    "marked": "^18.0.0",
    "postgres": "^3.4.8",
    "posthog-js": "^1.365.1",
    "posthog-node": "^5.29.1",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.7",
    "resend": "^6.10.0",
    "stripe": "^22.0.0",
    "zod": "^4.3.6"
  }
}
